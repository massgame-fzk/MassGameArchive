---
import "../styles/global.css";
import Icon from "../components/Icon.astro";
import ShareActions from "../components/ShareActions.astro";
import { site } from "../data/site";

type Props = {
  title: string;
  description?: string;
  image?: string;
  breadcrumbs?: {
    href?: string;
    label: string;
  }[];
};

const { title, description = site.description, image = site.ogImage, breadcrumbs = [] } = Astro.props;
const pageTitle = title === "トップ" ? site.name : `${title} | ${site.name}`;
const baseUrl = import.meta.env.DEV ? Astro.url : Astro.site ?? Astro.url;
const canonicalUrl = new URL(Astro.url.pathname, baseUrl).toString();
const imageUrl = new URL(image, baseUrl).toString();
const currentPath = Astro.url.pathname;
const nav = [
  { href: "/", label: "トップ", icon: "home" },
  { href: "/about/", label: "このサイトについて", icon: "book" },
  { href: "/years/", label: "年度", icon: "calendar" },
  { href: "/records/music/", label: "曲", icon: "music" },
  { href: "/records/media/", label: "動画", icon: "video" },
  { href: "/contribute/", label: "連絡・情報提供", icon: "info" },
] as const;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="theme-color" content="#f8fafc" />
    <meta name="apple-mobile-web-app-title" content={site.name} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">本文へ移動</a>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true"></span>
          <span>{site.name}</span>
        </a>
        <nav class="site-nav desktop-nav" aria-label="主要ナビゲーション">
          {nav.map((item) => {
            const isCurrent = item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);
            return (
              <a href={item.href} aria-current={isCurrent ? "page" : undefined}>
                <Icon name={item.icon} />{item.label}
              </a>
            );
          })}
        </nav>
        <details class="mobile-menu">
          <summary>
            <span class="menu-icon" aria-hidden="true"></span>
            <span>メニュー</span>
          </summary>
          <nav class="site-nav mobile-nav" aria-label="主要ナビゲーション">
            {nav.map((item) => {
              const isCurrent = item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);
              return (
                <a href={item.href} aria-current={isCurrent ? "page" : undefined}>
                  <Icon name={item.icon} />{item.label}
                </a>
              );
            })}
          </nav>
        </details>
      </div>
    </header>
    <main id="main">
      {breadcrumbs.length > 0 && (
        <nav class="breadcrumbs wrap narrow" aria-label="パンくず">
          <ol>
            <li><a href="/">トップ</a></li>
            {breadcrumbs.map((item, index) => (
              <li>
                {item.href && index < breadcrumbs.length - 1 ? (
                  <a href={item.href}>{item.label}</a>
                ) : (
                  <span aria-current="page">{item.label}</span>
                )}
              </li>
            ))}
          </ol>
        </nav>
      )}
      <slot />
    </main>
    <ShareActions title={pageTitle} text={description} url={canonicalUrl} />
    <footer class="site-footer">
      <div class="wrap footer-grid">
        <p>
          このサイトはOB/OGコミュニティ向けの非公式アーカイブです。広島大学附属中・高等学校の公式サイトではありません。
        </p>
        <p>
          掲載対象は曲名、年度、部門、場面、YouTube動画です。個人名、本文レポート、写真資料は公開対象にしていません。
        </p>
        <p>
          <a href="/about/">このサイトについて</a>
        </p>
      </div>
    </footer>
    <script>
      const root = document.documentElement;
      const header = document.querySelector(".site-header");
      const scrollHintShell = document.querySelector(".scroll-hint-shell");

      const setMeasuredHeight = (name: string, element: Element | null) => {
        if (!(element instanceof HTMLElement)) return;
        root.style.setProperty(name, `${element.getBoundingClientRect().height}px`);
      };

      const updateStickyOffsets = () => {
        setMeasuredHeight("--site-header-height", header);
        setMeasuredHeight("--scroll-hint-shell-height", scrollHintShell);
      };

      updateStickyOffsets();

      const ResizeObserverConstructor = globalThis.ResizeObserver;
      if (typeof ResizeObserverConstructor === "function") {
        const observer = new ResizeObserverConstructor(updateStickyOffsets);
        if (header instanceof HTMLElement) observer.observe(header);
        if (scrollHintShell instanceof HTMLElement) observer.observe(scrollHintShell);
      } else {
        globalThis.addEventListener("resize", updateStickyOffsets);
      }
    </script>
  </body>
</html>
