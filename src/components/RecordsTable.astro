---
import type { MusicEntry } from "../data/types";

type Props = {
  entries: MusicEntry[];
  searchable?: boolean;
};

const { entries, searchable = false } = Astro.props;
const years = [...new Set(entries.map((entry) => entry.year))].sort((a, b) => b - a);
const groups = [...new Set(entries.map((entry) => entry.group))];
---

{searchable && (
  <div class="filters" aria-label="曲一覧の絞り込み">
    <label>
      <span class="source-note">曲名・アーティスト</span>
      <input data-filter="query" type="search" placeholder="例: Gotthard" />
    </label>
    <label>
      <span class="source-note">年度</span>
      <select data-filter="year">
        <option value="">すべて</option>
        {years.map((year) => <option value={year}>{year}</option>)}
      </select>
    </label>
    <label>
      <span class="source-note">部門</span>
      <select data-filter="group">
        <option value="">すべて</option>
        {groups.map((group) => <option value={group}>{group}</option>)}
      </select>
    </label>
    <label>
      <span class="source-note">動画</span>
      <select data-filter="media">
        <option value="">指定なし</option>
        <option value="yes">動画あり年度</option>
      </select>
    </label>
  </div>
)}

<div class="table-wrap">
  <table data-records-table>
    <thead>
      <tr>
        <th>年度</th>
        <th>部門</th>
        <th>場面</th>
        <th>曲名</th>
        <th>アーティスト</th>
        <th>状態</th>
      </tr>
    </thead>
    <tbody>
      {entries.map((entry) => (
        <tr
          data-year={entry.year}
          data-group={entry.group}
          data-media={entry.year >= 2000 && entry.year <= 2011 ? "yes" : "no"}
          data-search={`${entry.title} ${entry.artist}`.toLowerCase()}
        >
          <td><a href={`/years/${entry.year}/`}>{entry.year}</a></td>
          <td>{entry.group}<span class="source-note"> / {entry.legacyGroup}</span></td>
          <td>{entry.scene}</td>
          <td>{entry.title}</td>
          <td>{entry.artist}</td>
          <td><span class="status">確認済み</span></td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

{searchable && (
  <script>
    const root = document.currentScript?.parentElement ?? document;
    const table = root.querySelector("[data-records-table]");
    const rows = Array.from(table?.querySelectorAll("tbody tr") ?? []);
    const getControl = (selector: string) => {
      const control = root.querySelector(selector);
      if (!(control instanceof HTMLInputElement || control instanceof HTMLSelectElement)) {
        throw new Error(`Missing filter control: ${selector}`);
      }
      return control;
    };
    const controls = {
      query: getControl("[data-filter='query']"),
      year: getControl("[data-filter='year']"),
      group: getControl("[data-filter='group']"),
      media: getControl("[data-filter='media']"),
    };
    const applyFilters = () => {
      const query = controls.query.value.trim().toLowerCase();
      const year = controls.year.value;
      const group = controls.group.value;
      const media = controls.media.value;
      for (const row of rows) {
        if (!(row instanceof HTMLTableRowElement)) continue;
        const visible =
          (!query || (row.dataset.search ?? "").includes(query)) &&
          (!year || row.dataset.year === year) &&
          (!group || row.dataset.group === group) &&
          (!media || row.dataset.media === media);
        row.hidden = !visible;
      }
    };
    Object.values(controls).forEach((control) => control.addEventListener("input", applyFilters));
  </script>
)}
