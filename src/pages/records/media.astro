---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareActions from "../../components/ShareActions.astro";
import { mediaEntries, youtubeEmbedUrl } from "../../data/archive";
import type { MediaEntry } from "../../data/types";

const sceneLabels = new Map([
  ["1部", "一部"],
  ["2部", "二部"],
  ["3部", "三部"],
]);

const sceneOrder = ["入場", "一部", "インター", "二部", "三部", "退場", "その他"];
const groupOrder = ["太陽", "月", "赤", "白", "不明"];

type VideoItem = {
  entry: MediaEntry;
  year: number;
  group: string;
  scene: string;
  detail: string;
  embedUrl: string;
};

function normalizeScene(value: string | undefined) {
  if (!value) return "その他";
  return sceneLabels.get(value) ?? value;
}

function rank(values: string[], value: string) {
  const index = values.indexOf(value);
  return index === -1 ? values.length : index;
}

function parseVideo(entry: MediaEntry): VideoItem | null {
  const match = entry.label.match(/^(\d{4})年度(?:\s+(.+))?$/);
  if (!match) return null;

  const [, yearValue, rest = ""] = match;
  const parts = rest.split(/\s+/).filter(Boolean);
  const group = parts[0] ?? "不明";
  const scene = normalizeScene(parts[1]);
  const detail = parts.slice(2).join(" ");

  return {
    entry,
    year: Number(yearValue),
    group,
    scene,
    detail,
    embedUrl: youtubeEmbedUrl(entry),
  };
}

const individualVideos = mediaEntries
  .filter((entry) => entry.kind === "youtube-video")
  .map(parseVideo)
  .filter((entry): entry is VideoItem => Boolean(entry))
  .sort((a, b) => {
    const byYear = b.year - a.year;
    if (byYear) return byYear;
    const byGroup = rank(groupOrder, a.group) - rank(groupOrder, b.group);
    if (byGroup) return byGroup;
    return rank(sceneOrder, a.scene) - rank(sceneOrder, b.scene);
  });

const groupedVideos = new Map<number, VideoItem[]>();
for (const entry of individualVideos) {
  groupedVideos.set(entry.year, [...(groupedVideos.get(entry.year) ?? []), entry]);
}
const videosByYear = [...groupedVideos].sort(([a], [b]) => b - a);
const archivePlaylists = mediaEntries
  .filter((entry) => entry.kind === "youtube-playlist")
  .sort((a, b) => {
    const aYear = Number(a.label.match(/\d{4}/)?.[0] ?? 0);
    const bYear = Number(b.label.match(/\d{4}/)?.[0] ?? 0);
    return bYear - aYear;
  });
---

<BaseLayout
  title="YouTube"
  description="広大附属マスゲームのYouTube動画を年度ごとに探せます。"
  breadcrumbs={[{ label: "動画" }]}
>
  <section class="hero wrap narrow">
    <p class="eyebrow">YouTube</p>
    <h1>動画</h1>
    <p class="lead">年度ごとに動画を探せます。埋め込み再生は必要な動画だけ読み込みます。</p>
    <ShareActions
      title="動画 | MassGame Archive"
      text="広大附属マスゲームのYouTube動画を年度ごとに探せます。"
    />
  </section>
  <section class="section wrap narrow">
    <div class="scroll-hint-shell">
      <p class="scroll-hint">年度は横にスクロールできます</p>
      <nav class="year-filter" aria-label="動画の年度">
        {videosByYear.map(([year]) => <a href={`#year-${year}`}>{year}</a>)}
        {archivePlaylists.length > 0 && <a href="#archive-playlists">2011以前</a>}
      </nav>
    </div>

    <div class="video-years">
      {videosByYear.map(([year, entries]) => (
        <section class="video-year" id={`year-${year}`} aria-labelledby={`year-${year}-title`}>
          <div class="section-heading">
            <h2 id={`year-${year}-title`}>{year}年度</h2>
            <a href={`/years/${year}/`}>年度ページ</a>
          </div>
          <div class="video-list">
            {entries.map((item) => (
              <article class="video-row">
                <div>
                  <p class="video-meta">
                    <span>{item.group}</span>
                    <span>{item.scene}</span>
                    {item.detail && <span>{item.detail}</span>}
                  </p>
                  <h3>{item.entry.label}</h3>
                </div>
                <div class="video-actions">
                  <button
                    type="button"
                    class="embed-toggle"
                    data-embed-url={item.embedUrl}
                    data-embed-title={`${item.entry.label} YouTube`}
                    disabled={!item.embedUrl}
                  >
                    このページで再生
                  </button>
                  <a class="youtube-link" href={item.entry.url}>YouTubeで見る</a>
                </div>
                <div class="embed-slot" aria-live="polite"></div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>

  {archivePlaylists.length > 0 && (
    <section class="section wrap narrow" id="archive-playlists">
      <div class="section-heading">
        <h2>2011年度以前のプレイリスト</h2>
      </div>
      <div class="playlist-list">
        {archivePlaylists.map((entry) => (
          <article class="playlist-row">
            <h3>{entry.label}</h3>
            <a class="youtube-link" href={entry.url}>YouTubeで見る</a>
          </article>
        ))}
      </div>
    </section>
  )}

  <script>
    const buttons = document.querySelectorAll("[data-embed-url]");
    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLButtonElement)) return;
        const url = button.dataset.embedUrl;
        if (!url) return;
        const row = button.closest(".video-row");
        const slot = row?.querySelector(".embed-slot");
        if (!slot) return;

        const existing = slot.querySelector("iframe");
        if (existing) {
          slot.replaceChildren();
          button.textContent = "このページで再生";
          return;
        }

        const iframe = document.createElement("iframe");
        iframe.src = url;
        iframe.title = button.dataset.embedTitle ?? "YouTube";
        iframe.loading = "lazy";
        iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
        iframe.allowFullscreen = true;
        slot.replaceChildren(iframe);
        button.textContent = "閉じる";
      });
    });
  </script>
</BaseLayout>
