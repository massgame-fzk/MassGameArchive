---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecordsTable from "../../components/RecordsTable.astro";
import { musicEntries } from "../../data/archive";

const sorted = [...musicEntries].sort((a, b) => b.year - a.year || a.group.localeCompare(b.group, "ja"));
---

<BaseLayout title="曲一覧">
  <section class="hero wrap narrow">
    <p class="eyebrow">Music</p>
    <h1>曲一覧</h1>
    <p class="lead">年度、部門、シーン、曲名・アーティストで絞り込み、列ごとに並べ替えできます。</p>
  </section>
  <section class="section wrap narrow">
    <RecordsTable entries={sorted} searchable />
  </section>
</BaseLayout>
