---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatEventDate, years } from "../../data/archive";

const sorted = [...years]
  .sort((a, b) => b.year - a.year)
  .map((entry) => ({
    ...entry,
    eventDateLabel: formatEventDate(entry.eventDate),
  }));

type DecadeEntry = (typeof sorted)[number];
const decadeMap = new Map<number, DecadeEntry[]>();
for (const entry of sorted) {
  const decade = Math.floor(entry.year / 10) * 10;
  const list = decadeMap.get(decade) ?? [];
  list.push(entry);
  decadeMap.set(decade, list);
}

const decades = [...decadeMap.entries()]
  .sort((a, b) => b[0] - a[0])
  .map(([decade, entries]) => ({ decade, entries }));
---

<BaseLayout title="年度別" breadcrumbs={[{ label: "年度別" }]}>
  <section class="hero wrap narrow">
    <p class="eyebrow">Years</p>
    <h1>年度別</h1>
    <p class="lead">曲またはYouTube動画が確認できる年度を中心に掲載しています。各年度ページで曲と動画を確認できます。</p>
  </section>

  {decades.length > 0 && (
    <nav class="year-decade-nav wrap narrow" aria-label="年代へジャンプ">
      {decades.map(({ decade }) => (
        <a class="year-decade-nav-item" href={`#decade-${decade}`}>{decade}年代</a>
      ))}
    </nav>
  )}

  {decades.map(({ decade, entries }) => (
    <section class="section wrap narrow year-decade-section" id={`decade-${decade}`}>
      <h2 class="year-decade-heading">{decade}年代</h2>
      <div class="year-grid">
        {entries.map((entry) => (
          <a class="year-card" href={`/years/${entry.year}/`}>
            <span class="year-card-number">{entry.year}</span>
            <span class="year-card-event">
              {entry.eventDateLabel ? `体育祭: ${entry.eventDateLabel}` : "体育祭の日付は未確認"}
            </span>
            {entry.summary && <span class="year-card-summary">{entry.summary}</span>}
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
