---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecordsTable from "../../components/RecordsTable.astro";
import ShareActions from "../../components/ShareActions.astro";
import { entriesForYear, youtubeEmbedUrl, years } from "../../data/archive";

export function getStaticPaths() {
  return years.map((entry) => ({ params: { year: String(entry.year) } }));
}

const yearParam = Number(Astro.params.year);
const record = entriesForYear(yearParam);
if (!record.year) {
  return Astro.redirect("/years/");
}
---

<BaseLayout
  title={`${record.year.label}`}
  description={`${record.year.label}の広大附属マスゲームの曲と動画をまとめています。`}
  breadcrumbs={[
    { href: "/years/", label: "年度別" },
    { label: record.year.label },
  ]}
>
  <section class="hero wrap narrow">
    <p class="eyebrow">Year</p>
    <h1>{record.year.label}</h1>
    {record.eventDateLabel && <p class="lead">体育祭: {record.eventDateLabel}</p>}
    <ShareActions
      title={`${record.year.label} | MassGame Archive`}
      text={`MassGame Archiveで${record.year.label}の曲と動画を見る`}
    />
  </section>

  <section class="section wrap narrow">
    <h2>曲</h2>
    {record.missingMusicComment && <p class="data-comment">{record.missingMusicComment}</p>}
    {record.music.length > 0 ? <RecordsTable entries={record.music} /> : <p>この年度の曲はまだ確認済みデータがありません。</p>}
  </section>

  <section class="section wrap narrow">
    <h2>YouTube</h2>
    {record.media.length > 0 ? (
      <div class="video-grid">
        {record.media.map((entry) => {
          const embedUrl = youtubeEmbedUrl(entry);
          return (
            <article class="video-item">
              <h3>{entry.label}</h3>
              <div class="video-actions">
                <button
                  type="button"
                  class="embed-toggle"
                  data-embed-url={embedUrl}
                  data-embed-title={`${entry.label} YouTube`}
                  disabled={!embedUrl}
                >
                  このページで再生
                </button>
                <a class="youtube-link" href={entry.url}>YouTubeで見る</a>
              </div>
              <div class="embed-slot" aria-live="polite"></div>
            </article>
          );
        })}
      </div>
    ) : (
      <p>この年度のYouTubeリンクは未確認です。</p>
    )}
  </section>
  <script>
    const buttons = document.querySelectorAll("[data-embed-url]");
    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLButtonElement)) return;
        const url = button.dataset.embedUrl;
        if (!url) return;
        const row = button.closest(".video-item");
        const slot = row?.querySelector(".embed-slot");
        if (!slot) return;

        const existing = slot.querySelector("iframe");
        if (existing) {
          slot.replaceChildren();
          button.textContent = "このページで再生";
          return;
        }

        const iframe = document.createElement("iframe");
        iframe.src = url;
        iframe.title = button.dataset.embedTitle ?? "YouTube";
        iframe.loading = "lazy";
        iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
        iframe.allowFullscreen = true;
        slot.replaceChildren(iframe);
        button.textContent = "閉じる";
      });
    });
  </script>
</BaseLayout>
