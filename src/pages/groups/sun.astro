---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecordsTable from "../../components/RecordsTable.astro";
import { musicEntries } from "../../data/archive";

const entries = musicEntries.filter((entry) => entry.group === "太陽" || entry.group === "赤");
---

<BaseLayout title="太陽・赤" breadcrumbs={[{ label: "太陽・赤" }]}>
  <section class="hero wrap narrow">
    <p class="eyebrow">Group</p>
    <h1>太陽・赤</h1>
    <p class="lead">旧呼称の赤と、2006年以降の太陽を横断して表示します。</p>
  </section>
  <section class="section wrap narrow">
    <h2>曲一覧</h2>
    <RecordsTable entries={entries} searchable />
  </section>
</BaseLayout>
